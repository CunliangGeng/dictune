{
  "name": "dictune",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:pwa": "bun run --filter @dictune/pwa dev",
    "dev:tui": "bun run --filter @dictune/tui dev",
    "build:pwa": "bun run --filter @dictune/pwa build",
    "build:tui": "bun run --filter @dictune/tui build",
    "typecheck": "bun run --filter '*' typecheck"
  }
}
