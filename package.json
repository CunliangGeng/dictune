{
  "name": "dictune",
  "private": true,
  "description": "Pronunciation clarity practice tool — PWA and TUI",
  "author": "Cunliang Geng <c.geng@esciencecenter.nl>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CunliangGeng/dictune.git"
  },
  "homepage": "https://github.com/CunliangGeng/dictune",
  "bugs": {
    "url": "https://github.com/CunliangGeng/dictune/issues"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:pwa": "bun run --filter @dictune/pwa dev",
    "dev:tui": "bun run --cwd packages/tui src/cli.tsx",
    "build:pwa": "bun run --filter @dictune/pwa build",
    "build:tui": "bun run --filter @dictune/tui build",
    "build:exe": "bun run --filter @dictune/tui build:exe",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bunx biome check packages/",
    "lint:fix": "bunx biome check --write packages/",
    "format": "bunx biome format --write packages/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6"
  }
}
